generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── センター（拠点）───────────────────────────────────────
model Center {
  id                     Int      @id @default(autoincrement())
  code                   String   @default("")   // 4桁センターコード 例: "3101"
  name                   String
  secretKey              String   @default("")
  isActive               Boolean  @default(true)
  openTime               String   @default("08:00")
  closeTime              String   @default("18:00")
  slotDurationMinutes    Int      @default(60)
  closedOnSunday         Boolean  @default(true)
  closedOnHoliday        Boolean  @default(true)
  hasBreak               Boolean  @default(false)
  breakStart             String   @default("12:00")
  breakEnd               String   @default("13:00")
  createdAt              DateTime @default(now())

  receptions   Reception[]
  reservations Reservation[]
}

// ─── システム設定 ─────────────────────────────────────────
model Setting {
  key   String @id
  value String @default("")
}

// ─── 運送会社 ──────────────────────────────────────────────
model Company {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  drivers Driver[]
}

// ─── ドライバー ────────────────────────────────────────────
model Driver {
  id          Int      @id @default(autoincrement())
  name        String   // カタカナ
  companyName String   // 運送会社名（スナップショット）
  phone       String   // 電話番号（重複あり：同番で複数名）
  isActive    Boolean  @default(true)
  companyId   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company?    @relation(fields: [companyId], references: [id])
  receptions Reception[]

  @@unique([phone, name, companyName], name: "driver_phone_name_company")
  @@index([phone])
}

// ─── 車両 ──────────────────────────────────────────────────
model Vehicle {
  id            Int      @id @default(autoincrement())
  region        String   @default("") // 地名
  classNum      String   @default("") // 分類番号
  hira          String   @default("") // ひらがな
  number        String   @default("") // 4桁数字
  vehicleNumber String   // フォーマット済み "多摩 500 あ 7917"
  maxLoad       String   @default("") // 最大積載量 kg
  phone         String   // 紐づく電話番号
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receptions Reception[]

  @@unique([vehicleNumber, phone], name: "vehicle_number_phone")
  @@index([phone])
  @@index([vehicleNumber])
}

// ─── ナンバープレート地名マスタ ────────────────────────────
model PlateRegion {
  id        Int     @id @default(autoincrement())
  name      String  // 地名 例: "多摩"
  kana      String  @default("") // 読み仮名 例: "たま"
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

// ─── ナンバープレートひらがなマスタ ────────────────────────
model PlateHiragana {
  id        Int     @id @default(autoincrement())
  char      String  // ひらがな1文字
  category  String  @default("business") // business / rental / unavailable
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

// ─── ナンバープレートアルファベットマスタ ──────────────────
model PlateAlphabet {
  id        Int     @id @default(autoincrement())
  char      String  // アルファベット1文字
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

// ─── バース予約 ────────────────────────────────────────────
model Reservation {
  id              Int      @id @default(autoincrement())
  centerId        Int
  phone           String   @default("")
  driverName      String   @default("")
  companyName     String   @default("")
  plateRegion     String   @default("")
  plateClassNum   String   @default("")
  plateHira       String   @default("")
  plateNumber     String   @default("")
  vehicleNumber   String   @default("")
  maxLoad         String   @default("")
  reservationDate DateTime // 予約日
  startTime       String   // "HH:mm"
  endTime         String   // "HH:mm"
  status          String   @default("pending") // pending / checked_in / completed / cancelled / no_show
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  center     Center      @relation(fields: [centerId], references: [id])
  receptions Reception[]

  @@index([phone, reservationDate])
  @@index([centerId, reservationDate])
}

// ─── 受付記録 ──────────────────────────────────────────────
model Reception {
  id            Int      @id @default(autoincrement())
  centerId      Int
  centerDailyNo Int      // その日のセンター内連番
  arrivedAt     DateTime @default(now())

  // 人情報（スナップショット）
  driverName  String
  companyName String
  phone       String

  // 車両情報（スナップショット）
  plateRegion   String @default("")
  plateClassNum String @default("")
  plateHira     String @default("")
  plateNumber   String @default("")
  vehicleNumber String @default("")
  maxLoad       String @default("")

  // 参照（任意: 既存ドライバー/車両/予約と紐づいている場合）
  driverId      Int?
  vehicleId     Int?
  reservationId Int?

  center      Center       @relation(fields: [centerId], references: [id])
  driver      Driver?      @relation(fields: [driverId], references: [id])
  vehicle     Vehicle?     @relation(fields: [vehicleId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([centerId, arrivedAt])
}
