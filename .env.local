# ─── API設定 ───────────────────────────────────────────────
# 同じNext.jsサーバーのAPIを使う（空のまま = 相対パス）
NEXT_PUBLIC_API_BASE=

# モックを無効化して本物のAPIを使う
NEXT_PUBLIC_USE_MOCK=false

# センターID（キオスク端末ごとに設定する）
NEXT_PUBLIC_CENTER_ID=1

# キオスク認証シークレット（センターのsecretKeyと一致させる）
NEXT_PUBLIC_KIOSK_SECRET=secret-danjiricenter
